# Moondream Vision API key (get free key at https://console.moondream.ai)
MOONDREAM_API_KEY=your_key_here

# Transport: "stdio" (default, for Claude Desktop) or "http" (for remote access)
TRANSPORT=stdio

# HTTP server port (only used when TRANSPORT=http)
PORT=3001

# Base URL for OAuth (only used when TRANSPORT=http, for Cloudflare tunnel)
# BASE_URL=https://resolve.yourdomain.com
